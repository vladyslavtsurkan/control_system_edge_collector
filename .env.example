# ── Required ─────────────────────────────────────────────
CLOUD_API_URL=https://api.my-iiot.com
X_API_KEY=your-m2m-api-key-here
AMQP_URL=amqp://guest:guest@localhost:5672/
AMQP_EXCHANGE=iiot_telemetry
AMQP_CONTROL_EXCHANGE=iiot_control_command
AMQP_USE_TLS=true
TLS_CA_CERT_PATH=/app/certs/ca_certificate.pem
TLS_CLIENT_CERT_PATH=/app/certs/collector_certificate.pem
TLS_CLIENT_KEY_PATH=/app/certs/collector_key.pem
# false is useful for local IP-based testing where cert SAN/CN may not match host
TLS_CHECK_HOSTNAME=false

# ── Optional: OPC UA client certificates ────────────────
# Required when security_policy != "None"
# OPCUA_CERT_PATH=/certs/client_cert.pem
# OPCUA_KEY_PATH=/certs/client_key.pem

# ── Optional: Health-check endpoint ─────────────────────
# HEALTH_HOST=0.0.0.0
# HEALTH_PORT=8080

# ── Optional: Store-and-forward buffer (SQLite) ──────────
# EDGE_BUFFER_DB_PATH=edge_buffer.db

# ── Optional: batching/backoff tuning ────────────────────
# BATCH_SIZE=100
# BATCH_TIMEOUT_S=1.0
# CONFIG_REFRESH_INTERVAL_S=300.0
# CONFIG_REFRESH_JITTER_S=10.0
# BACKOFF_BASE_S=1.0
# BACKOFF_MAX_S=60.0
# BACKOFF_MAX_RETRIES=5
# QUEUE_MAX_SIZE=10000  # legacy/deprecated (kept for compatibility)
